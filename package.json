{
  "name": "auto-finish",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "test": "pnpm -r test",
    "smoke:all": "pnpm --filter @auto-finish/orchestrator smoke:all",
    "dev": "pm2 start ecosystem.config.cjs",
    "dev:logs": "pm2 logs",
    "dev:status": "pm2 ls",
    "dev:monit": "pm2 monit",
    "dev:restart": "pm2 restart ecosystem.config.cjs",
    "dev:stop": "pm2 stop ecosystem.config.cjs",
    "dev:down": "pm2 delete ecosystem.config.cjs"
  },
  "devDependencies": {
    "pm2": "^7.0.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
