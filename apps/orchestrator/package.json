{
  "name": "@auto-finish/orchestrator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && cp -r src/db/migrations dist/db/migrations",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:all": "tsx scripts/smoke-all.ts",
    "dev": "tsx watch src/server.ts"
  },
  "dependencies": {
    "@alibaba-group/opensandbox": "^0.1.5",
    "@auto-finish/pipeline-schema": "workspace:*",
    "@auto-finish/project-schema": "workspace:*",
    "@hono/node-server": "^2.0.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "langfuse": "^3.38.20",
    "mitt": "^3.0.1",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.7.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
